{
    // ctrl + shift + B to build
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build main",
            "type": "shell",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-ggdb",
                "${workspaceFolder}/main.cpp",
                "-o",
                "${workspaceFolder}/out/ledbin"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Compile main.cpp"
        }
    ]
}